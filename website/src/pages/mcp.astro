---
import HeadCommon from '../components/HeadCommon.astro';
import { Repl } from '../repl/Repl';

const defaultCode = `// ── STRUDEL MCP ── AI-Controlled Live Coding ──────────────
//
// This REPL is connected to the Strudel MCP server.
// An AI agent (like Claude Code) can control this REPL
// remotely via strudel_* MCP tools.
//
// HOW TO START A LIVE SESSION:
//   1. Press ctrl+enter to verify audio works
//   2. Copy this entire code block from the editor
//   3. Paste it into your Claude Code terminal
//   4. Ask Claude to make music — it will use its MCP tools
//
// ── STRUDEL QUICK REFERENCE ──────────────────────────────
//
// BLOCKS: Each $: is an independent pattern. Separate blocks
// with blank lines. Always write ALL blocks — Strudel replaces
// the entire editor on each evaluation.
//
// MINI NOTATION (inside quotes):
//   space    sequence     "bd sd hh"     3 events per cycle
//   *n       repeat       "bd*4"         4 kicks per cycle
//   /n       slow down    "bd/2"         1 kick every 2 cycles
//   <>       alternate    "<c e g>"      rotate each cycle
//   []       group        "[bd sd] hh"   subdivide
//   ,        stack        "bd, hh*4"     play simultaneously
//   ~        rest         "bd ~ sd ~"    silence
//   (k,n)    euclidean    "bd(3,8)"      3 hits in 8 slots
//
// SYNTHS: "sawtooth" "square" "triangle" "sine" "supersaw"
// SAMPLES: s("bd sd hh cp").bank("RolandTR909")
//
// PITCH:    .scale("c:minor") .note("c4") .transpose(n)
// FILTER:   .lpf(freq) .lpq(q) .lpenv(depth) .ftype("ladder")
// ENVELOPE: .attack(t) .decay(t) .sustain(l) .release(t)
// EFFECTS:  .delay(wet) .room(wet) .pan(p) .distort(n)
// SIGNALS:  sine saw rand perlin — .range(min, max).slow(n)
// ORBIT:    .o(n) — route instruments to separate effect buses
//
// Full reference: http://localhost:4321/skill
//
// ── MCP TOOLS ────────────────────────────────────────────
//
// Use your strudel_* MCP tools to control this REPL.
// Run each tool's description to see usage details.
// Key tools:
//   strudel_get_code          read current editor code
//   strudel_set_and_evaluate  replace all code and play
//   strudel_evaluate          play current editor code
//   strudel_stop              silence everything
//   strudel_get_status        check playback state
//   strudel_set_cps           set tempo (0.5 = 120 BPM)
//
// Start by reading the current code with strudel_get_code,
// then modify and send back with strudel_set_and_evaluate.
// ──────────────────────────────────────────────────────────

// Trance starter — an open canvas to build on
$: n("<0 3 5 7>*4").scale("c:minor")
  .s("sawtooth").lpf(600)
  .lpenv(6).lpa(.005).lpd(.2).lps(0).lpq(10)
  .ftype("ladder").decay(.15).sustain(0)
  .delay(.3).o(1)

$: n("<0 5 3 7>").scale("c:minor").transpose(-12)
  .s("sawtooth").lpf(400).decay(.1).sustain(0).o(2)

$: s("bd*4, ~ cp ~ cp, [~ hh]*4").bank("RolandTR909").o(3)`;
---

<html lang="en" class="m-0 dark">
  <head>
    <HeadCommon />
    <title>Strudel REPL (MCP)</title>
  </head>
  <body class="h-app-height bg-background m-0">
    <Repl client:only="react" defaultCode={defaultCode} />
    <script is:inline>
      (function() {
        const WS_URL = 'ws://localhost:' + (window.__STRUDEL_MCP_PORT || 9001);
        let ws;
        let reconnectTimer;

        function connect() {
          ws = new WebSocket(WS_URL);

          ws.onopen = () => {
            console.log('[strudel-mcp] connected to', WS_URL);
            clearTimeout(reconnectTimer);
          };

          ws.onclose = () => {
            console.log('[strudel-mcp] disconnected, reconnecting in 2s...');
            reconnectTimer = setTimeout(connect, 2000);
          };

          ws.onerror = (err) => {
            console.error('[strudel-mcp] WebSocket error:', err);
          };

          ws.onmessage = async (event) => {
            let msg;
            try {
              msg = JSON.parse(event.data);
            } catch {
              console.error('[strudel-mcp] invalid JSON:', event.data);
              return;
            }

            const sm = window.strudelMirror;
            if (!sm) {
              ws.send(JSON.stringify({ id: msg.id, error: { message: 'strudelMirror not available yet' } }));
              return;
            }

            try {
              let result;
              switch (msg.method) {
                case 'setCode':
                  sm.setCode(msg.params.code);
                  result = { success: true };
                  break;
                case 'evaluate':
                  await sm.evaluate();
                  result = { success: true };
                  break;
                case 'setAndEvaluate':
                  sm.setCode(msg.params.code);
                  await sm.evaluate();
                  result = { success: true };
                  break;
                case 'stop':
                  await sm.stop();
                  result = { success: true };
                  break;
                case 'getCode':
                  result = { code: sm.code };
                  break;
                case 'setCps':
                  sm.repl.setCps(msg.params.cps);
                  result = { success: true };
                  break;
                case 'getStatus':
                  result = {
                    started: sm.repl.scheduler?.started ?? false,
                    cps: sm.repl.scheduler?.cps ?? null,
                    code: sm.code,
                  };
                  break;
                default:
                  throw new Error('Unknown method: ' + msg.method);
              }
              ws.send(JSON.stringify({ id: msg.id, result }));
            } catch (err) {
              ws.send(JSON.stringify({ id: msg.id, error: { message: err.message } }));
            }
          };
        }

        connect();

        window.__strudelMcpDisconnect = () => {
          clearTimeout(reconnectTimer);
          ws?.close();
          console.log('[strudel-mcp] manually disconnected');
        };
      })();
    </script>
  </body>
</html>
