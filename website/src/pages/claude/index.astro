---
import HeadCommon from '../../components/HeadCommon.astro';
import { Repl } from '../../repl/Repl';

const siteUrl = (Astro.site?.origin ?? 'http://localhost:4321').replace(/\/$/, '');
const defaultCode = `// ── STRUDEL + CLAUDE CODE ─────────────────────────────────
//
// Live code music with AI. This REPL connects to a local
// relay server that Claude Code controls via HTTP.
//
// HOW TO START:
//   1. Press ctrl+enter to test audio (you should hear a trance loop)
//   2. Copy this entire code block from the editor
//   3. Paste it into your Claude Code terminal
//   4. Claude will set up the relay and start making music
//
// ── RELAY SETUP (Claude will do this automatically) ──────
//
// mkdir -p /tmp/strudel-relay && cd /tmp/strudel-relay
// curl -sO ${siteUrl}/relay.mjs
// npm init -y 2>/dev/null && npm i ws 2>/dev/null
// node relay.mjs &
//
// ── HTTP API (how Claude controls the REPL) ──────────────
//
// Read current code:
//   curl -s http://localhost:9001/api/code
//
// Replace code and play:
//   curl -s -X POST http://localhost:9001/api/set-and-evaluate \\
//     --data-binary @/tmp/strudel-code.js
//
// Play / stop / status:
//   curl -s -X POST http://localhost:9001/api/evaluate
//   curl -s -X POST http://localhost:9001/api/stop
//   curl -s http://localhost:9001/api/status
//
// Set tempo (0.5 = 120 BPM):
//   curl -s -X POST http://localhost:9001/api/cps \\
//     -H 'Content-Type: application/json' -d '{"cps":0.5}'
//
// Workflow: write code to /tmp/strudel-code.js, then POST it.
//
// ── STRUDEL QUICK REFERENCE ──────────────────────────────
//
// Each $: is a pattern block. Separate with blank lines.
// Always send ALL blocks — Strudel replaces the entire editor.
//
// MINI NOTATION (inside quotes):
//   space    sequence     "bd sd hh"     3 events per cycle
//   *n       repeat       "bd*4"         4 kicks per cycle
//   /n       slow down    "bd/2"         every 2 cycles
//   <>       alternate    "<c e g>"      rotate each cycle
//   []       group        "[bd sd] hh"   subdivide
//   ,        stack        "bd, hh*4"     play simultaneously
//   ~        rest         "bd ~ sd ~"    silence
//   (k,n)    euclidean    "bd(3,8)"      3 hits in 8 slots
//
// SYNTHS: "sawtooth" "square" "triangle" "sine" "supersaw"
// SAMPLES: s("bd sd hh cp").bank("RolandTR909")
//
// PITCH:    .scale("c:minor") .note("c4") .transpose(n)
// FILTER:   .lpf(freq) .lpq(q) .lpenv(depth) .ftype("ladder")
// ENVELOPE: .attack(t) .decay(t) .sustain(l) .release(t)
// EFFECTS:  .delay(wet) .room(wet) .pan(p) .distort(n)
// SIGNALS:  sine saw rand perlin — .range(min, max).slow(n)
// ORBIT:    .o(n) — route instruments to separate effect buses
//
// Full reference: ${siteUrl}/claude/skill
// ──────────────────────────────────────────────────────────

// Trance starter — an open canvas to build on
$: n("<0 3 5 7>*4").scale("c:minor")
  .s("sawtooth").lpf(600)
  .lpenv(6).lpa(.005).lpd(.2).lps(0).lpq(10)
  .ftype("ladder").decay(.15).sustain(0)
  .delay(.3).o(1)

$: n("<0 5 3 7>").scale("c:minor").transpose(-12)
  .s("sawtooth").lpf(400).decay(.1).sustain(0).o(2)

$: s("bd*4, ~ cp ~ cp, [~ hh]*4").bank("RolandTR909").o(3)`;
---

<html lang="en" class="m-0 dark">
  <head>
    <HeadCommon />
    <title>Strudel REPL (Claude)</title>
  </head>
  <body class="h-app-height bg-background m-0">
    <Repl client:only="react" defaultCode={defaultCode} />
    <script is:inline>
      (function() {
        const WS_URL = 'ws://localhost:' + (window.__STRUDEL_RELAY_PORT || 9001);
        let ws;
        let reconnectTimer;

        function connect() {
          ws = new WebSocket(WS_URL);

          ws.onopen = () => {
            console.log('[strudel-relay] connected to', WS_URL);
            clearTimeout(reconnectTimer);
          };

          ws.onclose = () => {
            console.log('[strudel-relay] disconnected, reconnecting in 2s...');
            reconnectTimer = setTimeout(connect, 2000);
          };

          ws.onerror = (err) => {
            console.error('[strudel-relay] WebSocket error:', err);
          };

          ws.onmessage = async (event) => {
            let msg;
            try {
              msg = JSON.parse(event.data);
            } catch {
              console.error('[strudel-relay] invalid JSON:', event.data);
              return;
            }

            const sm = window.strudelMirror;
            if (!sm) {
              ws.send(JSON.stringify({ id: msg.id, error: { message: 'strudelMirror not available yet' } }));
              return;
            }

            try {
              let result;
              switch (msg.method) {
                case 'setCode':
                  sm.setCode(msg.params.code);
                  result = { success: true };
                  break;
                case 'evaluate':
                  await sm.evaluate();
                  result = { success: true };
                  break;
                case 'setAndEvaluate':
                  sm.setCode(msg.params.code);
                  await sm.evaluate();
                  result = { success: true };
                  break;
                case 'stop':
                  await sm.stop();
                  result = { success: true };
                  break;
                case 'getCode':
                  result = { code: sm.code };
                  break;
                case 'setCps':
                  sm.repl.setCps(msg.params.cps);
                  result = { success: true };
                  break;
                case 'getStatus':
                  result = {
                    started: sm.repl.scheduler?.started ?? false,
                    cps: sm.repl.scheduler?.cps ?? null,
                    code: sm.code,
                  };
                  break;
                default:
                  throw new Error('Unknown method: ' + msg.method);
              }
              ws.send(JSON.stringify({ id: msg.id, result }));
            } catch (err) {
              ws.send(JSON.stringify({ id: msg.id, error: { message: err.message } }));
            }
          };
        }

        connect();

        window.__strudelRelayDisconnect = () => {
          clearTimeout(reconnectTimer);
          ws?.close();
          console.log('[strudel-relay] manually disconnected');
        };
      })();
    </script>
  </body>
</html>
